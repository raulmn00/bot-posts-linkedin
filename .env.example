# ============================================================================
# .env.example — Bot de auto-publicação no LinkedIn
# Copie este arquivo para .env (NUNCA versionar .env) e preencha os valores.
# Em produção (Cloud Run), os mesmos nomes vêm do Secret Manager via --set-secrets.
# ============================================================================

# ---------- App ----------
ENV=dev                          # dev | prod
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
APP_BASE_URL=http://localhost:8080  # em prod: URL pública do Cloud Run

# ---------- Telegram ----------
# Obtido em @BotFather (/newbot). Formato: 1234567890:ABCdefGhI...
TELEGRAM_BOT_TOKEN=
# Seu chat_id pessoal (numérico). Obter via @userinfobot ou rodando /start no seu bot.
TELEGRAM_CHAT_ID=
# Token aleatório que VOCÊ define (>= 32 chars). Validado no header X-Telegram-Bot-Api-Secret-Token.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
TELEGRAM_WEBHOOK_SECRET=

# ---------- LinkedIn ----------
# Access token gerado no OAuth2 Tools do LinkedIn Developer Portal (vida útil 60 dias).
LINKEDIN_ACCESS_TOKEN=
# URN do seu profile pessoal — formato: urn:li:person:XXXXXXXXXX
# Obter chamando GET https://api.linkedin.com/v2/userinfo com o token acima e usar o campo "sub".
LINKEDIN_PERSON_URN=
LINKEDIN_API_VERSION=202506      # versão da REST API (atualizar a cada ~6 meses)
# ⚠️ MODO SEGURO: true = monta o payload e MOSTRA no Telegram sem publicar real.
# Mude para false APENAS quando quiser publicar de verdade no perfil pessoal.
# Default true por segurança — Fase F é o ponto irreversível do projeto.
LINKEDIN_DRY_RUN=true

# ---------- Anthropic (LLM + web search nativo) ----------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Limite de iterações de revisão (reprovação → correção) antes de forçar aprovar/cancelar.
MAX_REVISION_ITERATIONS=5
# Quantas buscas o tool web_search_20250305 pode disparar por geração de post (custo).
WEB_SEARCH_MAX_USES=3
# Tempo de vida do chat_state quando o bot está aguardando o motivo de uma reprovação.
# Expirado: a próxima mensagem do user não é mais tratada como motivo (é ignorada).
REVISION_PENDING_TTL_HOURS=24

# ---------- Replicate (geração de imagem — Flux 1.1 Pro) ----------
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-1.1-pro
# Timeout duro do polling de predição. Se estourar, o post vai sem foto + aviso.
REPLICATE_TIMEOUT_SECONDS=60

# ---------- Geração do post (Claude) ----------
# Path do arquivo com o system prompt customizado (persona do Raul).
POST_GENERATION_SYSTEM_PROMPT_PATH=prompts/post_generation_system.txt

# ---------- GitHub (busca em repos públicos de raulmn00) ----------
# PAT classic com escopo "public_repo" OU fine-grained "Public Repositories (read-only)".
GITHUB_TOKEN=
GITHUB_USERNAME=raulmn00

# ---------- GCP ----------
GCP_PROJECT_ID=
GCP_REGION=southamerica-east1    # São Paulo. Alternar para us-central1 se quiser menor latência p/ APIs IA.
# Bucket GCS onde a imagem gerada é persistida (URLs do Replicate expiram).
GCS_BUCKET_NAME=
# Fila do Cloud Tasks usada para processar geração em background (webhook responde rápido).
CLOUD_TASKS_QUEUE=bot-post-jobs
# Conta de serviço usada localmente para autenticar contra Firestore/GCS/Tasks/SecretManager.
# Em dev: caminho para o JSON da service account. Em prod (Cloud Run): NÃO setar — usa metadata server.
GOOGLE_APPLICATION_CREDENTIALS=
# TTL das URLs assinadas do GCS pro Telegram exibir a imagem. 7 dias cobre o ciclo de aprovação.
GCS_SIGNED_URL_TTL_MINUTES=10080

# ---------- Firestore ----------
# Em geral só precisa do GCP_PROJECT_ID. Coleção principal usada pela máquina de estados.
FIRESTORE_COLLECTION_POSTS=posts
# Estado da conversa com o user (TTL aplicado no get() do store).
FIRESTORE_COLLECTION_CHAT_STATES=chat_states
# G.3: dedup por update_id do Telegram (TTL via campo expires_at + TTL nativo).
FIRESTORE_COLLECTION_PROCESSED_UPDATES=processed_updates
PROCESSED_UPDATES_TTL_MINUTES=10
# G.3: path do worker que Cloud Tasks invoca pra processar tasks enfileiradas.
CLOUD_TASKS_WORKER_PATH=/internal/process-task
